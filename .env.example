# Copia este archivo a `.env` y rellena los valores.

# --- Base de datos ---
# Local (Docker, ver docker-compose.yml): puerto 5433 para no chocar con el 5432.
DATABASE_URL="postgresql://nexo:nexo_local_dev@localhost:5433/nexo?schema=public"
# Producción: cadena pooled de Neon en región EU (Frankfurt). Ejemplo:
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.eu-central-1.aws.neon.tech/nexo?sslmode=require"

# --- better-auth ---
# Secreto para firmar sesiones (mín. 32 caracteres). Genera uno con: openssl rand -base64 32
BETTER_AUTH_SECRET="genera_un_secreto_de_32+_caracteres"
# URL base de la app. En local: http://localhost:3300 — en prod: https://tu-dominio
BETTER_AUTH_URL="http://localhost:3300"

# --- Embeddings (Hugging Face Inference API) ---
# Vectoriza el texto de los tickets para sugerir artículos de la KB por
# similitud semántica. Token gratuito en: huggingface.co/settings/tokens
# (rol "read"). Sin él, la app funciona pero no muestra sugerencias.
HF_TOKEN="hf_..."
